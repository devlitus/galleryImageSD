---
import type { Image } from "../types/image.ts";
import FavoriteIcon from "./FavoriteIcon.astro";
import ImageModal from "./ImageModal.astro";

let resources: Image[] = [];
let fetchError: string | null = null;
try {
  const response = await fetch(`${Astro.url.origin}/api/search`);

  if (!response.ok) {
    throw new Error(`API responded with status: ${response.status}`);
  }

  const data = await response.json();

  if (data && data.resources) {
    resources = data.resources;
  } else {
    console.warn("API response did not contain 'resources'.", data);
    resources = [];
  }
} catch (error) {
  console.error("Error fetching images from API:", error);
  fetchError =
    error instanceof Error ? error.message : "An unknown error occurred";
  resources = [];
}
---

<div
  class="min-h-screen bg-white dark:bg-gray-900 transition-colors duration-200"
>
  {
    fetchError && (
      <div class="text-center text-red-500 p-4">
        Failed to load images: {fetchError}
      </div>
    )
  }

  <div
    class="columns-1 sm:columns-2 md:columns-3 lg:columns-4 gap-4 max-w-4xl mx-auto p-4 space-y-4"
  >
    {
      resources.map(({ secure_url, filename }: Image) => (
        <div class="relative break-inside-avoid mb-4 cursor-pointer hover:opacity-90 transition-opacity">
          <img
            src={secure_url}
            alt={filename}
            class="w-full rounded-lg gallery-image"
            loading="lazy"
          />
        </div>
      ))
    }
  </div>

  <ImageModal />
</div>
